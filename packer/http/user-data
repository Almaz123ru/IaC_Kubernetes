#cloud-config
autoinstall:
  version: 1
  locale: en_US
  keyboard:
    layout: us
  ssh:
    install-server: true
    allow-pw: true
    disable_root: true
    ssh_quiet_keygen: true
    allow_public_ssh_keys: true
  packages:
    - qemu-guest-agent
    - sudo
  storage:
    layout:
      name: direct
    swap:
      size: 0
  user-data:
    package_upgrade: false
    timezone: Asia/Yekaterinburg
    users:
      - name: ubuntu
        ssh_authorized_keys:
          - "YOUR_PUBLIC_SSH_KEY_FROM_PROXMOX"
        passwd: "YOUR_HASHED_PASSWD"
        groups: [adm, sudo]
        lock_passwd: false
        sudo: ALL=(ALL) NOPASSWD:ALL
        shell: /bin/bash
